+
+static int handshake_timer_running = 0;
+static int handshake_time_msg_mode = 0;
+static struct timespec handshake_start, handshake_end;
+
+static void handshake_time_msg_cb(int write_p, int version, int content_type,
+    const void *buf, size_t len, SSL *ssl, void *arg)
+{
+    const unsigned char *message = buf;
+
+    if (write_p && content_type == SSL3_RT_HANDSHAKE && len > 0
+        && message[0] == SSL3_MT_FINISHED && handshake_timer_running) {
+        double elapsed_ms;
+
+        if (clock_gettime(CLOCK_MONOTONIC, &handshake_end) == 0) {
+            elapsed_ms = (handshake_end.tv_sec - handshake_start.tv_sec)
+                * 1000.0
+                + (handshake_end.tv_nsec - handshake_start.tv_nsec)
+                / 1000000.0;
+            BIO_printf(bio_err, "TLS_HANDSHAKE_TIME_MS=%.6f\n", elapsed_ms);
+        }
+        handshake_timer_running = 0;
+    }
+
+#ifndef OPENSSL_NO_SSL_TRACE
+    if (handshake_time_msg_mode == 2)
+        SSL_trace(write_p, version, content_type, buf, len, ssl, arg);
+    else
+#endif
+        if (handshake_time_msg_mode == 1)
+            msg_cb(write_p, version, content_type, buf, len, ssl, arg);
+}

